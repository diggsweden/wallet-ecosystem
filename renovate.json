{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>diggsweden/.github//renovate-base.json"],
  "packageRules": [
    {
      "description": "Group EU Digital Identity Wallet docker images",
      "matchDatasources": ["docker"],
      "groupName": "EU Digital Identity Wallet images",
      "matchPackageNames": ["/^ghcr.io/eu-digital-identity-wallet//"]
    },
    {
      "description": "Group Digg wallet docker images",
      "matchDatasources": ["docker"],
      "groupName": "Digg wallet images",
      "matchPackageNames": ["/^ghcr.io/diggsweden/wallet-/"]
    },
    {
      "description": "Group infrastructure docker images",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "postgres",
        "traefik",
        "valkey/valkey",
        "quay.io/keycloak/keycloak"
      ],
      "groupName": "Infrastructure images"
    }
  ]
}
